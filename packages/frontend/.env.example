# URL base da API (usada pelo Axios client)
# Em desenvolvimento sem Docker, aponta para o backend local
# Com Docker, o proxy do Vite ou nginx resolve automaticamente
VITE_API_URL=/api

# Mock Service Worker (MSW) — opt-in, DESLIGADO por padrao.
# So habilite ("true") para desenvolver a UI sem backend; os mocks guardam
# dados apenas em memoria (somem ao recarregar a pagina) e NAO persistem no banco.
# VITE_ENABLE_MSW=true
